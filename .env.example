# Villager AI Environment Configuration
# Copy this file to .env and update with your values

# LLM Provider Configuration (choose one)
# Option 1: Ollama (recommended - free and uncensored)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1-uncensored

# Option 2: DeepSeek API (alternative)
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=your-deepseek-api-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# OPENAI_API_KEY=your-deepseek-api-key-here

# Option 3: OpenAI API (alternative)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key-here

# GitHub Integration (optional - for repository management)
GITHUB_TOKEN=your-github-token-here

# Villager Server Configuration
VILLAGER_BASE_URL=http://127.0.0.1:37695
VILLAGER_HOST=0.0.0.0
VILLAGER_PORT=37695

# HexStrike Integration
HEXSTRIKE_BASE_URL=http://127.0.0.1:8000

# Security Settings (for red team operations)
ALLOW_SHELL=1
ALLOW_APT=1
ALLOW_WRITE=1
ALLOW_BUILD=1

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=villager.log
PYTHONUNBUFFERED=1

# MCP Client Configuration
MCP_CLIENT_BASE_URL=http://localhost:25989
