# ===============================================
# Villager AI Framework - Environment Configuration
# ===============================================
# 
# This file contains all the environment variables needed to configure
# the Villager AI Framework. Copy this file to .env and customize it.
#
# Quick Setup:
#   1. Copy this file: cp .env.example .env
#   2. Edit .env with your preferred settings
#   3. Run tests: ./tests/run_tests.sh
#
# ===============================================

# ===============================================
# AI MODEL CONFIGURATION (Choose ONE option)
# ===============================================

# OPTION 1: Ollama (RECOMMENDED - Free & Uncensored)
# ===============================================
# Ollama runs AI models locally on your computer - completely free!
# No API keys needed, no usage limits, no censorship.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1-uncensored

# To use Ollama:
#   1. Install Ollama: https://ollama.ai/
#   2. Pull the model: ollama pull deepseek-r1-uncensored
#   3. Start Ollama: ollama serve
#   4. That's it! No API keys needed.

# OPTION 2: DeepSeek API (Alternative)
# ===============================================
# Uncomment these lines if you prefer DeepSeek API instead of Ollama
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=your-deepseek-api-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# OPENAI_API_KEY=your-deepseek-api-key-here

# OPTION 3: OpenAI API (Alternative)
# ===============================================
# Uncomment these lines if you prefer OpenAI API instead of Ollama
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key-here

# ===============================================
# GITHUB INTEGRATION (Optional)
# ===============================================
# GitHub integration allows Villager to manage repositories,
# create issues, and discover security tools automatically.
# 
# To get a GitHub token:
#   1. Go to GitHub.com → Settings → Developer settings → Personal access tokens
#   2. Generate new token with 'repo' and 'read:org' permissions
#   3. Copy the token and paste it below
GITHUB_TOKEN=your-github-token-here

# ===============================================
# VILLAGER SERVER CONFIGURATION
# ===============================================
# These settings control the Villager web server
VILLAGER_BASE_URL=http://127.0.0.1:37695
VILLAGER_HOST=0.0.0.0
VILLAGER_PORT=37695

# ===============================================
# HEXSTRIKE INTEGRATION
# ===============================================
# HexStrike provides additional security tools and capabilities
# Make sure HexStrike is running on this URL
HEXSTRIKE_BASE_URL=http://127.0.0.1:8000

# ===============================================
# SECURITY SETTINGS
# ===============================================
# These settings control what Villager is allowed to do
# For red team operations, set all to 1
# For restricted environments, set to 0
ALLOW_SHELL=1
ALLOW_APT=1
ALLOW_WRITE=1
ALLOW_BUILD=1

# ===============================================
# LOGGING CONFIGURATION
# ===============================================
# Control how much information Villager logs
LOG_LEVEL=INFO
LOG_FILE=villager.log
PYTHONUNBUFFERED=1

# ===============================================
# MCP CLIENT CONFIGURATION
# ===============================================
# MCP (Model Context Protocol) allows AI assistants to use Villager
MCP_CLIENT_BASE_URL=http://localhost:25989

# ===============================================
# QUICK START CHECKLIST
# ===============================================
# 
# ✅ Copy this file to .env: cp .env.example .env
# ✅ Choose your AI provider (Ollama recommended)
# ✅ If using Ollama: Install and start it
# ✅ If using APIs: Add your API keys
# ✅ Optional: Add GitHub token for repository features
# ✅ Run tests: ./tests/run_tests.sh
# ✅ Start Villager: ./start_villager_proper.sh
#
# Need help? Check docs/README.md for detailed instructions!
