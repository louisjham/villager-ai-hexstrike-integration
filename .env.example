# Villager AI Environment Configuration
# Copy this file to .env and update with your values

# ──────────────────────────────────────────────────────
# LLM Provider Configuration
# ──────────────────────────────────────────────────────

# Primary: Z.AI Coding Plan (GLM-4.7 / GLM-5)
# Get your API key at: https://z.ai/manage-apikey/apikey-list
# Subscribe at: https://z.ai/subscribe
LLM_PROVIDER=zai
ZAI_API_KEY=your-zai-api-key-here
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_MODEL=glm-4.7

# Backup: OpenRouter (automatic failover)
# Get your API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=zhipu/glm-5

# To use OpenRouter as primary instead of Z.AI:
# LLM_PROVIDER=openrouter

# GitHub Integration (optional - for repository management)
GITHUB_TOKEN=your-github-token-here

# Villager Server Configuration
VILLAGER_BASE_URL=http://127.0.0.1:37695
VILLAGER_HOST=0.0.0.0
VILLAGER_PORT=37695

# HexStrike Integration
HEXSTRIKE_BASE_URL=http://127.0.0.1:8000

# Security Settings
ALLOW_SHELL=1
ALLOW_APT=1
ALLOW_WRITE=1
ALLOW_BUILD=1

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=villager.log
PYTHONUNBUFFERED=1

# MCP Client Configuration
MCP_CLIENT_BASE_URL=http://localhost:25989
