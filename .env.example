# Villager AI Environment Configuration
# Copy this file to .env and update with your values

# LLM Provider Configuration (choose one)
# Option 1: DeepSeek API (no local RAM required)
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=your-deepseek-api-key-here

# Option 2: OpenAI API (great alternative)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key-here

# Option 3: Ollama (requires high RAM - 8GB+ recommended)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=deepseek-r1-uncensored

# GitHub Integration (optional - for repository management)
GITHUB_TOKEN=your-github-token-here

# Villager Server Configuration
VILLAGER_BASE_URL=http://127.0.0.1:37695
VILLAGER_HOST=0.0.0.0
VILLAGER_PORT=37695

# HexStrike Integration
HEXSTRIKE_BASE_URL=http://127.0.0.1:8000

# Security Settings (These are crucial for the villager, allows model shell access)

ALLOW_SHELL=1 # Direct command shell execution 
ALLOW_APT=1   # Allows the package management such as installing/updating the tools
ALLOW_WRITE=1 # Grants rights to the docker filesystems
ALLOW_BUILD=1 # Permits the build operations like compiling,Docker images etc.

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=villager.log
PYTHONUNBUFFERED=1

# MCP Client Configuration
MCP_CLIENT_BASE_URL=http://localhost:25989
