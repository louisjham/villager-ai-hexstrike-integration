# Villager AI Environment Configuration
# Copy this file to .env and update with your values

# DeepSeek AI Configuration (required)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=your-deepseek-api-key-here

# GitHub Integration (required for tool discovery)
GITHUB_TOKEN=your-github-token-here

# Server Configuration
VILLAGER_BASE_URL=http://127.0.0.1:37695
VILLAGER_HOST=0.0.0.0
VILLAGER_PORT=37695

# HexStrike Integration
HEXSTRIKE_BASE_URL=http://127.0.0.1:8000

# Python Configuration
PYTHONUNBUFFERED=1

# Security Settings (optional)
ALLOW_SHELL=1
ALLOW_APT=1
ALLOW_WRITE=1
ALLOW_BUILD=1

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=villager.log
