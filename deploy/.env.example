# Villager AI Docker Environment Configuration
# Copy this file to .env and update with your values

# LLM Provider Configuration (choose one)
# Option 1: Ollama (recommended - free and uncensored)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=deepseek-r1-uncensored

# Option 2: DeepSeek API (alternative)
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=your-deepseek-api-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# OPENAI_API_KEY=your-deepseek-api-key-here

# GitHub Integration (optional)
GITHUB_TOKEN=your-github-token-here

# Server Configuration
VILLAGER_HOST=0.0.0.0
VILLAGER_PORT=37695

# Python Configuration
PYTHONUNBUFFERED=1

# Security Settings
ALLOW_SHELL=1
ALLOW_APT=1
ALLOW_WRITE=1
ALLOW_BUILD=1

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=villager.log
